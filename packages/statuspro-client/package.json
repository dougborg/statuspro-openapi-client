{
  "name": "statuspro-client",
  "version": "0.1.0",
  "description": "TypeScript client for the StatusPro API with automatic retries, rate-limit awareness, and pagination",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "generate": "openapi-ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "statuspro",
    "order-status",
    "api",
    "client",
    "openapi",
    "typescript"
  ],
  "author": "Doug Borg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dougborg/statuspro-openapi-client.git",
    "directory": "packages/statuspro-client"
  },
  "bugs": {
    "url": "https://github.com/dougborg/statuspro-openapi-client/issues"
  },
  "homepage": "https://github.com/dougborg/statuspro-openapi-client/tree/main/packages/statuspro-client#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@hey-api/openapi-ts": "^0.88.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.15",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "semantic-release": "^24.2.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.15"
  },
  "sideEffects": false
}
