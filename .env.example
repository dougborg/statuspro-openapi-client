# StatusPro API Configuration
# Copy this file to .env and fill in your actual values

# Required: Your StatusPro API key
# Can also be set via:
# - STATUSPRO_API_KEY environment variable
# - ~/.netrc file (machine app.orderstatuspro.com/api/v1, password field)
# - api_key parameter to StatusProClient()
STATUSPRO_API_KEY=your_api_key_here

# Optional: StatusPro API base URL (defaults to production)
STATUSPRO_BASE_URL=https://app.orderstatuspro.com/api/v1

# Optional: Development settings
DEBUG=false
LOG_LEVEL=INFO

# Test configuration (for integration tests)
# Set these if you want to run integration tests
# STATUSPRO_TEST_API_KEY=your_test_api_key_here
# STATUSPRO_TEST_BASE_URL=https://app.orderstatuspro.com/api/v1

# Alternative: Use ~/.netrc for centralized credential management
# Add to ~/.netrc:
#   machine app.orderstatuspro.com/api/v1
#   password your-api-key-here
# Then chmod 600 ~/.netrc
